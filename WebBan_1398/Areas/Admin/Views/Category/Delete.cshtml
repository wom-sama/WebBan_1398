@model WebBan_1398.Models.Category

@{
    ViewData["Title"] = "Xác nhận xóa";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="card shadow-lg border-danger">
                <div class="card-header bg-danger text-white py-4">
                     <h2 class="section-title text-white mb-0">Xác Nhận Xóa Loại Sản Phẩm <i class="fa-solid fa-triangle-exclamation"></i></h2>
                </div>
                <div class="card-body p-5">
                    <h4 class="mb-4">Bạn có chắc chắn muốn xóa loại sản phẩm: <strong>@Model.Name</strong>?</h4>
                    
                    <p class="text-danger fw-bold">Hành động này không thể hoàn tác và có thể ảnh hưởng đến các sản phẩm thuộc loại này!</p>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-5">
                            <button type="submit" class="btn btn-danger btn-lg"><i class="fa-solid fa-trash-alt"></i> Vâng, Xóa!</button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg mt-2 mt-md-0"><i class="fa-solid fa-times-circle"></i> Không, Quay Lại</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
