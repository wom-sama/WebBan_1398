@model WebBan_1398.Areas.Admin.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Bảng điều khiển";
}

<div class="container py-5">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h1 class="section-title mb-2">Bảng Điều Khiển Admin <i class="fa-solid fa-chart-line"></i></h1>
            <p class="text-muted mb-0">Tổng quan nhanh về cửa hàng và các thao tác quản trị chính.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a asp-area="Admin" asp-controller="Product" asp-action="Add" class="btn btn-primary">Thêm sản phẩm</a>
            <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-primary-outline">Xem đơn hàng</a>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="admin-stat-card">
                <span class="stat-label">Sản phẩm</span>
                <strong>@Model.ProductCount</strong>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="admin-stat-card">
                <span class="stat-label">Danh mục</span>
                <strong>@Model.CategoryCount</strong>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="admin-stat-card">
                <span class="stat-label">Đơn hàng</span>
                <strong>@Model.OrderCount</strong>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="admin-stat-card">
                <span class="stat-label">Người dùng</span>
                <strong>@Model.UserCount</strong>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="summary-card h-100">
                <h3>Thao tác nhanh</h3>
                <div class="d-grid gap-3 mt-3">
                    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-primary-outline">Quản lý sản phẩm</a>
                    <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-primary-outline">Quản lý danh mục</a>
                    <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-primary-outline">Quản lý đơn hàng</a>
                    <a asp-area="" asp-controller="Product" asp-action="Index" class="btn btn-primary">Xem cửa hàng</a>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="summary-card h-100">
                <h3>Đơn hàng gần đây</h3>
                @if (Model.RecentOrders.Any())
                {
                    <div class="table-responsive mt-3">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Mã đơn</th>
                                    <th>Khách hàng</th>
                                    <th>Ngày đặt</th>
                                    <th class="text-end">Tổng tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.RecentOrders)
                                {
                                    <tr>
                                        <td><a asp-area="Admin" asp-controller="Order" asp-action="Details" asp-route-id="@order.Id">#@order.Id</a></td>
                                        <td>@(order.ApplicationUser?.FullName ?? order.ApplicationUser?.Email ?? "Khách hàng")</td>
                                        <td>@order.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="text-end">@order.TotalPrice.ToString("N0")₫</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0 mt-3">Chưa có đơn hàng nào được tạo.</p>
                }
            </div>
        </div>
    </div>
</div>
