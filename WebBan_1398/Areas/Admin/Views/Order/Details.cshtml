@model WebBan_1398.Models.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="container py-5">
    <div class="summary-card shadow-sm">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
            <div>
                <h1 class="section-title mb-2">Chi Tiết Đơn Hàng #@Model.Id</h1>
                <p class="text-muted mb-0">Ngày đặt: @Model.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-primary-outline">Quay lại</a>
                <a asp-area="Admin" asp-controller="Order" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger rounded-pill">Xóa đơn hàng</a>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-6">
                <h3>Thông tin khách hàng</h3>
                <div class="summary-line"><span>Họ tên</span><strong>@(Model.ApplicationUser?.FullName ?? "Không có")</strong></div>
                <div class="summary-line"><span>Email</span><strong>@(Model.ApplicationUser?.Email ?? "Không có")</strong></div>
                <div class="summary-line"><span>Địa chỉ giao hàng</span><strong>@Model.ShippingAddress</strong></div>
                <div class="summary-line"><span>Ghi chú</span><strong>@(string.IsNullOrWhiteSpace(Model.Notes) ? "Không có" : Model.Notes)</strong></div>
            </div>
            <div class="col-lg-6">
                <h3>Tóm tắt thanh toán</h3>
                <div class="summary-line"><span>Số sản phẩm</span><strong>@Model.OrderDetails.Sum(item => item.Quantity)</strong></div>
                <div class="summary-line total"><span>Tổng tiền</span><strong>@Model.TotalPrice.ToString("N0")₫</strong></div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Sản phẩm</th>
                        <th class="text-center">Số lượng</th>
                        <th class="text-end">Đơn giá</th>
                        <th class="text-end">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderDetails)
                    {
                        <tr>
                            <td>@(item.Product?.Name ?? $"Sản phẩm #{item.ProductId}")</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">@item.Price.ToString("N0")₫</td>
                            <td class="text-end">@((item.Quantity * item.Price).ToString("N0"))₫</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
