@using Microsoft.AspNetCore.Identity

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var currentUser = SignInManager.IsSignedIn(User) ? await UserManager.GetUserAsync(User) : null;
    var displayName = currentUser?.FullName ?? UserManager.GetUserName(User) ?? "Tài khoản";
}

<ul class="navbar-nav align-items-lg-center gap-lg-2">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <span class="nav-link text-dark fw-semibold">Xin chào, @displayName</span>
    </li>
    @if (User.IsInRole(SD.Role_Admin))
    {
        <li class="nav-item">
            <a class="nav-link menu-link" asp-area="Identity" asp-page="/Account/Register">Tạo tài khoản</a>
        </li>
    }
    <li class="nav-item">
        <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button id="logout" type="submit" class="nav-link btn btn-link text-dark border-0">Đăng xuất</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link menu-link" id="register" asp-area="Identity" asp-page="/Account/Register">Đăng ký</a>
    </li>
    <li class="nav-item">
        <a class="nav-link menu-link" id="login" asp-area="Identity" asp-page="/Account/Login">Đăng nhập</a>
    </li>
}
</ul>
