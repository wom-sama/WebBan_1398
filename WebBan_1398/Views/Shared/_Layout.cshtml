<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Hoài Nam Shop</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Đảm bảo bạn đã copy style.css vào thư mục wwwroot/css/ -->
    <link rel="stylesheet" href="~/css/Style.css">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>

    <!-- Thanh điều hướng -->
    <nav id="main-nav" class="navbar navbar-expand-lg bg-white sticky-top">
        <div class="container">
            <a class="navbar-brand" id="logo" asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-heart"></i> HNKStore
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
                <ul class="navbar-nav gap-lg-4 my-3 my-lg-0">
                    <li class="nav-item"><a asp-controller="Home" asp-action="Index" class="nav-link menu-link">Trang Chủ</a></li>
                    <li class="nav-item"><a asp-controller="Product" asp-action="Index" class="nav-link menu-link">Sản Phẩm</a></li>
                    <li class="nav-item"><a href="/#new-arrivals" class="nav-link menu-link">Mới Về</a></li>
                    <li class="nav-item"><a href="/#limited-edition" class="nav-link menu-link">Giới Hạn</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Quản Lý
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                            <li><a class="dropdown-item" asp-controller="Category" asp-action="Index">Loại Sản Phẩm</a></li>
                            <li><a class="dropdown-item" asp-controller="Product" asp-action="Add">Thêm Sản Phẩm</a></li>
                        </ul>
                    </li>
                    <li class="nav-item"><a href="#footer" class="nav-link menu-link">Liên Hệ</a></li>
                </ul>
            </div>

            <!-- Search Form -->
            <form asp-controller="Product" asp-action="Index" method="get" class="d-flex search-form mx-lg-3">
                <input class="form-control me-2" type="search" placeholder="Tìm kiếm sản phẩm..." aria-label="Search" name="searchString">
                <button class="btn btn-outline-success" type="submit"><i class="fa-solid fa-search"></i></button>
            </form>

            <div class="cart-icon ms-lg-3">
                <i class="fa-solid fa-cart-shopping"></i>
                <span class="badge">3</span>
            </div>
        </div>
    </nav>

    @RenderBody()

    <footer id="footer">
        <div class="container">
            <div class="row footer-container">
                <div class="col-md-4 footer-section">
                    <h3>Về HNKStore</h3>
                    <p> chính hãng với giá cả hợp lý. Chúng tôi cam kết mang lại niềm vui cho mọi khách hàng.</p>
                </div>
                <div class="col-md-4 footer-section">
                    <h3>Liên Kết Nhanh</h3>
                    <ul>
                        <li><a asp-controller="Home" asp-action="Index">Trang Chủ</a></li>
                        <li><a asp-controller="Product" asp-action="Index">Sản Phẩm Mới</a></li>
                        <li><a href="#">Chính Sách Bảo Hành</a></li>
                    </ul>
                </div>
                <div class="col-md-4 footer-section">
                    <h3>Kết Nối</h3>
                    <p><i class="fa-solid fa-envelope"></i> nguyennamnhn125@gmail.com</p>
                    <p><i class="fa-solid fa-phone"></i> 0373356007</p>
                    <div class="social-icons">
                        <a href="#"><i class="fa-brands fa-facebook"></i></a>
                        <a href="#"><i class="fa-brands fa-instagram"></i></a>
                        <a href="#"><i class="fa-brands fa-tiktok"></i></a>
                    </div>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 HNKStore</p>
        </div>
    </footer>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>