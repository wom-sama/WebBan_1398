@model IEnumerable<WebBan_1398.Models.Product>

@{
    ViewData["Title"] = "Trang chủ";
    var products = Model ?? Enumerable.Empty<WebBan_1398.Models.Product>();
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<header id="hero-banner">
    <div class="container">
        <h1 class="hero-title">Thế Giới Figure Anime</h1>
        <p class="hero-desc">Khám phá bộ sưu tập figure độc đáo, giá tốt và trải nghiệm mua sắm mượt mà trên HNKStore.</p>
        <a asp-area="" asp-controller="Product" asp-action="Index" class="btn btn-primary">Xem tất cả sản phẩm</a>
    </div>
    <div class="floating-shapes">
        <i class="fa-solid fa-star shape-1"></i>
        <i class="fa-solid fa-heart shape-2"></i>
        <i class="fa-solid fa-gem shape-3"></i>
    </div>
</header>

<div id="featured-products" class="container category-section py-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <h2 class="section-title mb-0">Sản Phẩm Nổi Bật <i class="fa-solid fa-star"></i></h2>
        @if (User.IsInRole(SD.Role_Admin))
        {
            <div class="d-flex flex-wrap gap-2">
                <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="btn btn-primary-outline">Bảng điều khiển</a>
                <a asp-area="Admin" asp-controller="Product" asp-action="Add" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Thêm sản phẩm</a>
            </div>
        }
    </div>

    <div class="row g-4">
        @if (products.Any())
        {
            @foreach (var product in products)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="product-card h-100">
                        <div class="product-image">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@Url.Content(product.ImageUrl)" alt="@product.Name">
                            }
                            else
                            {
                                <img src="~/Image/placeholder.png" alt="No Image Available">
                            }
                            <div class="overlay">
                                <a asp-area="" asp-controller="Product" asp-action="Display" asp-route-id="@product.Id" class="btn btn-secondary">Xem Chi Tiết</a>
                            </div>
                        </div>
                        <div class="product-info">
                            <h3 class="product-name">@product.Name</h3>
                            <p class="product-price">@product.Price.ToString("N0")₫</p>
                            <a asp-area="" asp-controller="ShoppingCart" asp-action="AddToCart" asp-route-productId="@product.Id" asp-route-quantity="1" asp-route-returnUrl="@returnUrl" class="btn btn-add">
                                Thêm vào giỏ
                            </a>
                            @if (User.IsInRole(SD.Role_Admin))
                            {
                                <div class="d-flex justify-content-between mt-3 pt-3 border-top">
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Update" asp-route-id="@product.Id" class="btn btn-sm btn-outline-secondary rounded-pill"><i class="fa-solid fa-pen"></i> Sửa</a>
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@product.Id" class="btn btn-sm btn-outline-danger rounded-pill"><i class="fa-solid fa-trash"></i> Xóa</a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="empty-state">
                    <h3>Chưa có sản phẩm nào</h3>
                    <p>Dữ liệu sản phẩm sẽ xuất hiện tại đây ngay khi bạn thêm vào hệ thống.</p>
                </div>
            </div>
        }
    </div>
</div>

<div id="new-arrivals" class="container category-section py-4">
    <h2 class="section-title">Khám Phá Cửa Hàng <i class="fa-solid fa-bolt"></i></h2>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="info-card h-100">
                <h3>Giao diện hiện đại</h3>
                <p>Trang chủ, danh sách sản phẩm, chi tiết, giỏ hàng và quản trị đều dùng cùng phong cách nhất quán.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="info-card h-100">
                <h3>Tìm kiếm nhanh</h3>
                <p>Tìm sản phẩm theo tên hoặc danh mục ngay trên thanh điều hướng mà không cần đổi trang trước.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="info-card h-100">
                <h3>Đặt hàng thuận tiện</h3>
                <p>Thêm vào giỏ, checkout và xác nhận đơn hàng được hiển thị rõ ràng, dễ theo dõi hơn trước.</p>
            </div>
        </div>
    </div>
</div>
