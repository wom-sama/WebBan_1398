@model WebBan_1398.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<div class="container my-5">
    <div class="row bg-white p-4 rounded shadow-sm">
        <div class="col-md-6">
            <div class="product-image-large">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Url.Content(Model.ImageUrl)" class="img-fluid rounded" alt="@Model.Name">
                }
                else
                {
                    <img src="~/images/placeholder.png" class="img-fluid rounded" alt="No Image Available">
                }
            </div>
        </div>
        <div class="col-md-6">
            <div class="product-details-info text-dark">
                <h1 style="color: #ff69b4;">@Model.Name</h1>
                <hr>
                <p class="lead">@Model.Description</p>
                <p class="fs-2 fw-bold" style="color: #ff1493;">@Model.Price.ToString("N0")₫</p>
                <div class="mt-4">
                    <button class="btn btn-add btn-lg w-100">Thêm vào giỏ hàng <i class="fa-solid fa-cart-plus"></i></button>
                </div>
                <div class="mt-3">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill w-100">Tiếp tục mua sắm</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Script xử lý thêm vào giỏ hàng cho trang chi tiết
        document.querySelector('.btn-add').addEventListener('click', function(e) {
            const img = document.querySelector('.product-image-large img');
            const cartIcon = document.querySelector('.cart-icon');
            const badge = cartIcon.querySelector('.badge');
            const clone = img.cloneNode(true);
            const imgRect = img.getBoundingClientRect();
            const cartRect = cartIcon.getBoundingClientRect();

            clone.style.position = 'fixed';
            clone.style.top = imgRect.top + 'px';
            clone.style.left = imgRect.left + 'px';
            clone.style.width = imgRect.width + 'px';
            clone.style.height = imgRect.height + 'px';
            clone.style.zIndex = '9999';
            clone.style.objectFit = 'cover';
            clone.style.borderRadius = '1rem';
            clone.style.transition = 'all 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55)';
            document.body.appendChild(clone);
            clone.style.animation = 'shatter-shake 0.5s forwards';
            setTimeout(() => {
                clone.style.animation = 'none';
                clone.style.top = (cartRect.top + cartRect.height / 2 - 20) + 'px';
                clone.style.left = (cartRect.left + cartRect.width / 2 - 20) + 'px';
                clone.style.width = '40px';
                clone.style.height = '40px';
                clone.style.opacity = '0';
                clone.style.transform = 'rotate(720deg) scale(0.1)';
                clone.style.borderRadius = '50%';
            }, 400);
            setTimeout(() => {
                clone.remove();
                let count = parseInt(badge.innerText);
                badge.innerText = count + 1;
                cartIcon.style.animation = 'cart-bump 0.3s';
                setTimeout(() => { cartIcon.style.animation = 'none'; }, 300);
            }, 1200);
        });
    </script>
}