@model WebBan_1398.Models.Product

@{
    ViewData["Title"] = "Cập nhật sản phẩm";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-light py-4">
                    <h2 class="section-title text-center mb-0">Chỉnh Sửa Sản Phẩm <i class="fa-solid fa-edit"></i></h2>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Update" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold">Tên sản phẩm</label>
                            <input asp-for="Name" class="form-control form-control-lg" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Price" class="form-label fw-bold">Giá</label>
                            <input asp-for="Price" class="form-control form-control-lg" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                            <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CategoryId" class="form-label fw-bold">Loại sản phẩm</label>
                            <select asp-for="CategoryId" asp-items="@ViewBag.Categories" class="form-select form-select-lg">
                                <option value="">-- Chọn loại sản phẩm --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label for="imageUrl" class="form-label fw-bold">Hình ảnh mới (tùy chọn)</label>
                            <input type="file" name="imageUrl" id="imageUrl" class="form-control" />
                            <div class="mt-2">
                                <span class="form-text">Hình ảnh hiện tại:</span>
                                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                {
                                    <img src="@Url.Content(Model.ImageUrl)" alt="Current Image" style="max-width: 100px; border-radius: 5px;" />
                                }
                                else
                                {
                                    <span>Không có</span>
                                }
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-5">
                            <button type="submit" class="btn btn-primary btn-lg"><i class="fa-solid fa-save"></i> Lưu thay đổi</button>
                            <a asp-action="Index" class="btn btn-outline-secondary mt-2">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
