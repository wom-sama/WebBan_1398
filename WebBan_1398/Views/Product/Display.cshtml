@model WebBan_1398.Models.Product

@{
    ViewData["Title"] = Model.Name;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="container my-5">
    <div class="card product-detail-card shadow-lg border-0 rounded-lg overflow-hidden">
        <div class="row g-0">
            <div class="col-lg-6 product-detail-image-wrapper">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Url.Content(Model.ImageUrl)" class="img-fluid" alt="@Model.Name">
                }
                else
                {
                    <img src="~/Image/placeholder.png" class="img-fluid" alt="No Image Available">
                }

                @if (Model.Images.Any())
                {
                    <div class="product-gallery p-3">
                        @foreach (var image in Model.Images)
                        {
                            <img src="@Url.Content(image.Url)" alt="@Model.Name" class="gallery-thumb">
                        }
                    </div>
                }
            </div>
            <div class="col-lg-6 d-flex flex-column">
                <div class="card-body p-5">
                    <h1 class="product-detail-title">@Model.Name</h1>

                    @if (Model.Category != null)
                    {
                        <div class="category-badge">
                            <i class="fa-solid fa-tag me-2"></i>@Model.Category.Name
                        </div>
                    }

                    <p class="product-detail-price">@Model.Price.ToString("N0")₫</p>

                    <div class="product-detail-description my-4">
                        <h5 class="fw-bold">Mô tả sản phẩm</h5>
                        <p>@Model.Description</p>
                    </div>

                    <div class="d-grid gap-2 mt-auto">
                        <a asp-area="" asp-controller="ShoppingCart" asp-action="AddToCart" asp-route-productId="@Model.Id" asp-route-quantity="1" asp-route-returnUrl="@returnUrl" class="btn btn-primary btn-lg">
                            <i class="fa-solid fa-cart-plus"></i> Thêm vào giỏ hàng
                        </a>
                        <a asp-area="" asp-controller="Product" asp-action="Index" class="btn btn-primary-outline">Quay lại danh sách</a>
                        <div class="d-flex justify-content-between mt-3">
                            @if (ViewBag.PreviousProductId != null)
                            {
                                <a asp-area="" asp-controller="Product" asp-action="Display" asp-route-id="@ViewBag.PreviousProductId" class="btn btn-outline-primary"><i class="fa-solid fa-arrow-left"></i> Sản phẩm trước</a>
                            }
                            else
                            {
                                <span></span>
                            }

                            @if (ViewBag.NextProductId != null)
                            {
                                <a asp-area="" asp-controller="Product" asp-action="Display" asp-route-id="@ViewBag.NextProductId" class="btn btn-outline-primary">Sản phẩm tiếp theo <i class="fa-solid fa-arrow-right"></i></a>
                            }
                        </div>
                    </div>
                </div>

                @if (User.IsInRole(SD.Role_Admin))
                {
                    <div class="card-footer bg-light text-center p-3 d-flex flex-wrap justify-content-center gap-2">
                        <a asp-area="Admin" asp-controller="Product" asp-action="Update" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary rounded-pill"><i class="fa-solid fa-pen"></i> Sửa</a>
                        <a asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger rounded-pill"><i class="fa-solid fa-trash"></i> Xóa</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
