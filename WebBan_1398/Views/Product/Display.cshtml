@model WebBan_1398.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<div class="container my-5">
    <div class="card product-detail-card shadow-lg border-0 rounded-lg overflow-hidden">
        <div class="row g-0">
            <div class="col-lg-6 product-detail-image-wrapper">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Url.Content(Model.ImageUrl)" class="img-fluid" alt="@Model.Name">
                }
                else
                {
                    <img src="~/Image/placeholder.png" class="img-fluid" alt="No Image Available">
                }
            </div>
            <div class="col-lg-6 d-flex flex-column">
                <div class="card-body p-5">
                    <h1 class="product-detail-title">@Model.Name</h1>
                    
                    @if (Model.Category != null)
                    {
                        <div class="category-badge">
                            <i class="fa-solid fa-tag me-2"></i>@Model.Category.Name
                        </div>
                    }

                    <p class="product-detail-price">@Model.Price.ToString("N0")₫</p>
                    
                    <div class="product-detail-description my-4">
                        <h5 class="fw-bold">Mô Tả Sản Phẩm</h5>
                        <p>@Model.Description</p>
                    </div>

                    <div class="d-grid gap-2 mt-auto">
                        <button class="btn btn-primary btn-lg btn-add"><i class="fa-solid fa-cart-plus"></i> Thêm vào giỏ hàng</button>
                        <a asp-action="Index" class="btn btn-outline-secondary mt-2">Quay lại danh sách</a>
                        <div class="d-flex justify-content-between mt-3">
                            @if (ViewBag.PreviousProductId != null)
                            {
                                <a href="@Url.Action("Display", new { id = ViewBag.PreviousProductId })" class="btn btn-outline-primary"><i class="fa-solid fa-arrow-left"></i> Sản phẩm trước</a>
                            }
                            else
                            {
                                <a href="#" class="btn btn-outline-primary disabled"><i class="fa-solid fa-arrow-left"></i> Sản phẩm trước</a>
                            }

                            @if (ViewBag.NextProductId != null)
                            {
                                <a href="@Url.Action("Display", new { id = ViewBag.NextProductId })" class="btn btn-outline-primary">Sản phẩm tiếp theo <i class="fa-solid fa-arrow-right"></i></a>
                            }
                            else
                            {
                                <a href="#" class="btn btn-outline-primary disabled">Sản phẩm tiếp theo <i class="fa-solid fa-arrow-right"></i></a>
                            }
                        </div>
                    </div>
                </div>
                 <div class="card-footer bg-light text-center p-3">
                    <a asp-controller="Product" asp-action="Update" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary rounded-pill mx-1"><i class="fa-solid fa-pen"></i> Sửa</a>
                    <a asp-controller="Product" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger rounded-pill mx-1"><i class="fa-solid fa-trash"></i> Xóa</a>
                </div>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <script>
        // Script to handle 'Add to Cart' animation
        document.querySelector('.btn-add').addEventListener('click', function(e) {
            const img = document.querySelector('.product-detail-image-wrapper img');
            const cartIcon = document.querySelector('.cart-icon');
            const badge = cartIcon.querySelector('.badge');
            const clone = img.cloneNode(true);
            const imgRect = img.getBoundingClientRect();
            const cartRect = cartIcon.getBoundingClientRect();

            clone.style.position = 'fixed';
            clone.style.top = imgRect.top + 'px';
            clone.style.left = imgRect.left + 'px';
            clone.style.width = imgRect.width + 'px';
            clone.style.height = 'auto';
            clone.style.zIndex = '9999';
            clone.style.borderRadius = '10px';
            clone.style.transition = 'all 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55)';
            document.body.appendChild(clone);
            
            clone.style.animation = 'shatter-shake 0.5s forwards';

            setTimeout(() => {
                clone.style.animation = 'none';
                clone.style.top = (cartRect.top + cartRect.height / 2 - 20) + 'px';
                clone.style.left = (cartRect.left + cartRect.width / 2 - 20) + 'px';
                clone.style.width = '40px';
                clone.style.height = '40px';
                clone.style.opacity = '0';
                clone.style.transform = 'rotate(720deg) scale(0.1)';
                clone.style.borderRadius = '50%';
            }, 400);

            setTimeout(() => {
                clone.remove();
                let count = parseInt(badge.innerText);
                badge.innerText = count + 1;
                cartIcon.style.animation = 'cart-bump 0.3s';
                setTimeout(() => { cartIcon.style.animation = 'none'; }, 300);
            }, 1200);
        });
    </script>
}
