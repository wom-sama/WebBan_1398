@model IEnumerable<WebBan_1398.Models.Product>

@{
    ViewData["Title"] = "Sản phẩm";
    var products = Model ?? Enumerable.Empty<WebBan_1398.Models.Product>();
    var currentFilter = ViewData["CurrentFilter"] as string;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="container category-section py-5">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            @if (!string.IsNullOrWhiteSpace(currentFilter))
            {
                <h1 class="section-title mb-2">Kết quả tìm kiếm cho "@currentFilter"</h1>
                <p class="text-muted mb-0">Danh sách bên dưới đã được lọc theo từ khóa bạn vừa nhập.</p>
            }
            else
            {
                <h1 class="section-title mb-2">Tất Cả Sản Phẩm <i class="fa-solid fa-boxes-stacked"></i></h1>
                <p class="text-muted mb-0">Duyệt toàn bộ sản phẩm đang có trong cửa hàng.</p>
            }
        </div>

        @if (User.IsInRole(SD.Role_Admin))
        {
            <div class="d-flex flex-wrap gap-2">
                <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-primary-outline">Quản lý sản phẩm</a>
                <a asp-area="Admin" asp-controller="Product" asp-action="Add" class="btn btn-primary">Thêm sản phẩm</a>
            </div>
        }
    </div>

    <div class="row g-4">
        @if (products.Any())
        {
            @foreach (var product in products)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="product-card h-100">
                        <div class="product-image">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@Url.Content(product.ImageUrl)" alt="@product.Name">
                            }
                            else
                            {
                                <img src="~/Image/placeholder.png" alt="No Image Available">
                            }
                            <div class="overlay">
                                <a asp-area="" asp-controller="Product" asp-action="Display" asp-route-id="@product.Id" class="btn btn-secondary">Xem Chi Tiết</a>
                            </div>
                        </div>
                        <div class="product-info">
                            <h3 class="product-name">@product.Name</h3>
                            @if (product.Category != null)
                            {
                                <p class="text-muted mb-1">@product.Category.Name</p>
                            }
                            <p class="product-price">@product.Price.ToString("N0")₫</p>
                            <a asp-area="" asp-controller="ShoppingCart" asp-action="AddToCart" asp-route-productId="@product.Id" asp-route-quantity="1" asp-route-returnUrl="@returnUrl" class="btn btn-add">
                                Thêm vào giỏ
                            </a>
                            @if (User.IsInRole(SD.Role_Admin))
                            {
                                <div class="d-flex justify-content-between mt-3 pt-3 border-top">
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Update" asp-route-id="@product.Id" class="btn btn-sm btn-outline-secondary rounded-pill"><i class="fa-solid fa-pen"></i> Sửa</a>
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@product.Id" class="btn btn-sm btn-outline-danger rounded-pill"><i class="fa-solid fa-trash"></i> Xóa</a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="empty-state">
                    <h3>Không tìm thấy sản phẩm phù hợp</h3>
                    <p>Hãy thử lại với từ khóa khác hoặc quay về danh sách sản phẩm đầy đủ.</p>
                    <a asp-area="" asp-controller="Product" asp-action="Index" class="btn btn-primary mt-3">Xem tất cả sản phẩm</a>
                </div>
            </div>
        }
    </div>
</div>
