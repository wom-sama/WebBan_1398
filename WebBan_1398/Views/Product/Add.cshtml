@using WebBan_1398.Models
@model WebBan_1398.Models.Product

@{
    ViewData["Title"] = "Thêm sản phẩm mới";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-light py-4">
                    <h2 class="section-title text-center mb-0">Thêm Sản Phẩm Mới <i class="fa-solid fa-plus-circle"></i></h2>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Add" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold">Tên sản phẩm</label>
                            <input asp-for="Name" class="form-control form-control-lg" placeholder="Nhập tên sản phẩm..." />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Price" class="form-label fw-bold">Giá</label>
                            <input asp-for="Price" class="form-control form-control-lg" placeholder="Nhập giá tiền..." />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                            <textarea asp-for="Description" class="form-control" rows="5" placeholder="Nhập mô tả chi tiết cho sản phẩm..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CategoryId" class="form-label fw-bold">Loại sản phẩm</label>
                            <select asp-for="CategoryId" asp-items="@ViewBag.Categories" class="form-select form-select-lg">
                                <option value="">-- Chọn loại sản phẩm --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label for="imageUrl" class="form-label fw-bold">Hình ảnh</label>
                            <input type="file" name="imageUrl" id="imageUrl" class="form-control" />
                        </div>

                        <div class="d-grid gap-2 mt-5">
                            <button type="submit" class="btn btn-primary btn-lg"><i class="fa-solid fa-save"></i> Lưu sản phẩm</button>
                            <a asp-action="Index" class="btn btn-outline-secondary mt-2">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
